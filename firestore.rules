rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidShipment(data) {
      return data.keys().hasAll(['trackingNumber', 'sender', 'receiver', 'cargo', 'quote', 'status', 'createdAt', 'updatedAt'])
        && data.keys().size() == 8
        && data.trackingNumber is string && data.trackingNumber.size() <= 32
        && data.status in ['Pending', 'In Transit', 'Arrived', 'Delivered']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.sender is map
        && data.receiver is map
        && data.cargo is map
        && data.quote is map;
    }

    match /shipments/{shipmentId} {
      allow get: if isValidId(shipmentId);
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidShipment(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidShipment(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
