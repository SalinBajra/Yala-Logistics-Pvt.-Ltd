{
  "entities": {
    "Shipment": {
      "title": "Shipment",
      "description": "Represents a cargo movement request and its lifecycle.",
      "type": "object",
      "properties": {
        "trackingNumber": { "type": "string", "description": "Unique tracking ID (e.g., YALA-123456)" },
        "sender": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["name", "email", "phone", "address"]
        },
        "receiver": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["name", "email", "phone", "address"]
        },
        "cargo": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["Courier", "Cargo", "Freight", "Sea"] },
            "weight": { "type": "number" },
            "commodity": { "type": "string" },
            "value": { "type": "number" }
          },
          "required": ["type", "weight", "commodity", "value"]
        },
        "quote": {
          "type": "object",
          "properties": {
            "basePrice": { "type": "number" },
            "customsFee": { "type": "number" },
            "total": { "type": "number" },
            "id": { "type": "string" },
            "date": { "type": "string" }
          },
          "required": ["basePrice", "customsFee", "total", "id", "date"]
        },
        "status": { "type": "string", "enum": ["Pending", "In Transit", "Arrived", "Delivered"], "description": "Current status of the shipment" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trackingNumber", "sender", "receiver", "cargo", "quote", "status", "createdAt", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "System administrators with management privileges.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/shipments/{shipmentId}": {
      "schema": "Shipment",
      "description": "Store all cargo consignments."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Whitelist of administrator UIDs."
    }
  }
}
